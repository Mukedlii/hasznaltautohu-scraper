{
    "title": "Hasznaltauto.hu Scraper Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "searchUrl": {
            "title": "Keresési URL",
            "type": "string",
            "description": "A hasznaltauto.hu keresési URL (pl. szűrve márkára, árra, évjáratra)",
            "editor": "textfield",
            "default": "https://www.hasznaltauto."
        },
        "maxPages": {
            "title": "Max oldalak száma",
            "type": "integer",
            "description": "Hány oldalt scrapeljen le maximum",
            "default": 5,
            "minimum": 1,
            "maximum": 50
        },
        "minPrice": {
            "title": "Minimum ár (Ft)",
            "type": "integer",
            "description": "Ennél olcsóbb autókat kiszűri",
            "editor": "number"
        },
        "maxPrice": {
            "title": "Maximum ár (Ft)",
            "type": "integer",
            "description": "Ennél drágább autókat kiszűri",
            "editor": "number"
        },
        "maxKm": {
            "title": "Maximum km állás",
            "type": "integer",
            "description": "Ennél több km-rel rendelkező autókat kiszűri",
            "editor": "number"
        },
        "minYear": {
            "title": "Minimum évjárat",
            "type": "integer",
            "description": "Ennél régebbi autókat kiszűri (pl. 2015)",
            "editor": "number"
        }
    },
    "required": ["searchUrl"]
}
